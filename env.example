APP_ENVIRONMENT=production
SERVICE_VERSION=0.5.0
API_CONTRACT_VERSION=2026-07-21.2
GIT_COMMIT_SHA=replace-with-deployed-commit
BUSINESS_TIMEZONE=Europe/Moscow

SUVVY_WEBHOOK_TOKEN=
# Optional grace token for an explicitly planned rotation; clear after cutover.
SUVVY_PREVIOUS_WEBHOOK_TOKEN=
# Transitional only: keep true until SUVVY sends Authorization: Bearer.
SUVVY_ALLOW_BODY_TOKEN=true

# Enable only after SUVVY sends a stable, non-PII chat_id.
SEARCH_GUARD_ENABLED=false
SEARCH_GUARD_DB_PATH=/data/search_guard.sqlite3
SEARCH_GUARD_HMAC_SECRET=
SEARCH_GUARD_NAMESPACE=suvvy-tourvisor
SEARCH_GUARD_TTL_SECONDS=259200
SEARCH_GUARD_MAX_SEARCHES=2
SEARCH_RESULT_REPLAY_TTL_SECONDS=45
SEARCH_GUARD_PRUNE_INTERVAL_SECONDS=15
# Set true only after Amvera /data survives a controlled application restart.
SEARCH_GUARD_PERSISTENCE_VERIFIED=false

MOCK_TOURVISOR=false
TOURVISOR_API_BASE_URL=https://api.tourvisor.ru
TOURVISOR_JWT=
TOURVISOR_CURRENCY=RUB
TOURVISOR_TIMEOUT_SECONDS=20
TOURVISOR_POLL_ATTEMPTS=4
TOURVISOR_POLL_INTERVAL_SECONDS=2
TOURVISOR_RESULTS_LIMIT=25
# Keep unverified until the live priceFrom/pagination/sort contract check is approved.
TOURVISOR_API_CONTRACT_VERSION=unverified
TOURVISOR_PRICE_FROM_ENABLED=false

OPERATOR_REGISTRY_PATH=config/operator_registry.json
TOURVISOR_MIN_HOTEL_RATING=4.0
MAX_DEPARTURE_WINDOW_DAYS=7
MAX_NIGHTS_RANGE=10

TOURVISOR_ENABLE_HOTEL_IMAGES=true
TOURVISOR_HOTEL_IMAGES_LIMIT=1
TOURVISOR_ENABLE_ROOM_IMAGES=true
TOURVISOR_ROOM_IMAGES_LIMIT=2

SUVVY_TOURS_LIMIT=3
SUVVY_ROOM_IMAGES_PER_TOUR=1
SUVVY_COMPACT_OUTPUT=true

ENABLE_DEBUG_ENDPOINTS=false
EXPOSE_API_DOCS=false
LOG_LEVEL=INFO
